# ============================================================
# SAE Fullstack — Variáveis de Ambiente (Produção)
#
# 1. Copie:  cp .env.example .env
# 2. Edite os valores abaixo antes de executar docker compose
# 3. Execute:  docker compose up -d --build
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── MongoDB ──────────────────────────────────────────────────
MONGODB_USER=mongo
MONGODB_PASSWORD=mongo123

# ─── MinIO (Object Storage) ───────────────────────────────────
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── Frontend / CORS ──────────────────────────────────────────
# URL pública do frontend (usada para CORS e links de email)
# Exemplo: http://192.168.1.100  ou  https://sae.meudominio.mz
FRONTEND_URL=https://smartsae.co.mz

# URL do gateway que o browser usa para chamar a API
# Deve ser acessível a partir do browser do utilizador final
VITE_API_GATEWAY_URL=http://187.77.71.198:8080

# ─── Email (Gmail App Password) ───────────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENABLED=false

# ─── SMS Gateway (Ozeki) ──────────────────────────────────────
OZEKI_URL=localhost
OZEKI_PORT=9500

# ─── IA — Anthropic Claude (forum + quiz) ─────────────────────
# Necessário para funcionalidades de fórum e quiz com IA
ANTHROPIC_API_KEY=

# ─── IA — OpenAI (serviço Python FastAPI) ─────────────────────
# Necessário para o serviço sae-ai-python (chat, recomendações, acessibilidade)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# MAPA DE PORTAS (VPS firewall — abrir apenas o necessário):
#
#   80    → Frontend (Nginx/React)
#   8080  → API Gateway (acesso dos clientes)
#   9000  → MinIO S3 API (uso interno — pode fechar ao exterior)
#   9001  → MinIO Console (uso interno — pode fechar ao exterior)
#   15672 → RabbitMQ Management (uso interno — pode fechar ao exterior)
#
# Portas internas (não expor ao exterior):
#   8081  sae-auth-service
#   8082  sae-content-service
#   8083  sae-forum-service
#   8084  sae-quiz-service
#   8085  sae-academic-service
#   8086  sae-ai-service (Java)
#   8087  sae-ai-python (FastAPI)
#
# APÓS O PRIMEIRO ARRANQUE — carregar dados iniciais:
#   docker compose exec postgres psql -U postgres -d sae_db -f /docker-entrypoint-initdb.d/seed.sql
# ============================================================
