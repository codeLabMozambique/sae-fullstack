# ============================================================
# SAE Fullstack — Variáveis de Ambiente (Produção)
# 1. Copie: cp .env.example .env
# 2. Edite os valores abaixo antes de executar docker compose
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── MinIO (Object Storage) ───────────────────────────────
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── Frontend / CORS ──────────────────────────────────────
# URL pública do frontend (usada para CORS e links de email)
# Exemplo: http://192.168.1.100  ou  https://sae.meudominio.mz
FRONTEND_URL=http://SEU_IP_VPS

# URL do gateway que o browser usa para chamar a API
# Deve ser acessível a partir do browser do utilizador final
VITE_API_GATEWAY_URL=http://SEU_IP_VPS:8080

# ─── Email (Gmail App Password) ───────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENABLED=false

# ─── SMS Gateway (Ozeki) ──────────────────────────────────
OZEKI_URL=localhost
OZEKI_PORT=9500

# ─── IA (Anthropic Claude) ────────────────────────────────
# Necessário para funcionalidades de fórum e quiz com IA
ANTHROPIC_API_KEY=

# ============================================================
# APÓS O PRIMEIRO ARRANQUE:
#   Execute os dados iniciais do sistema:
#   docker compose exec postgres psql -U postgres -d sae_db -f /docker-entrypoint-initdb.d/seed.sql
#
# NOTA: seed.sql e seed-test-data.sql devem ser executados
#   manualmente DEPOIS que os serviços criarem as tabelas
#   via Hibernate (ddl-auto: update).
# ============================================================
