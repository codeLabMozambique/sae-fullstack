# ─── API Keys ────────────────────────────────────────────────────────────────
# Copie este ficheiro para .env (gitignored) e preencha os valores reais.
# Em produção (VPS), o ficheiro .env fica na raiz do projecto junto ao docker-compose.yml.

# OpenAI — usado pelo forum-service (auto-resposta IA) e quiz-service (geração de quizzes)
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic — usado pelo quiz-service (oral tests com Claude)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── URLs dos serviços (opcional para dev local — os valores por omissão já funcionam) ──
# AUTH_SERVICE_URL=http://localhost:8081
# ACADEMIC_SERVICE_URL=http://localhost:8085

# ─── Base de dados (opcional — por omissão usa postgres@localhost:5432/sae_db) ──────────
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/sae_db
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=postgres

# ─── WebSocket origins (forum-service) ──────────────────────────────────────────────────
# WS_ORIGINS=http://localhost:5173,http://localhost:8080
