            "cwd": "${workspaceFolder}",
            "mainClass": "codelab.api.smart.sae.AcademicServiceApplication",
            "projectName": "sae-academic-service",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "java",
            "name": "Spring Boot-GatewayApplication<sae-api-gateway>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "codelab.api.smart.sae.GatewayApplication",
            "projectName": "sae-api-gateway",
            "args": "",
            "envFile": "${workspaceFolder}/.env",
            "vmArgs": " -Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.port=64100 -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false -Dspring.jmx.enabled=true -Djava.rmi.server.hostname=localhost -Dspring.application.admin.enabled=true -Dspring.boot.project.name=sae-api-gateway"
        },
